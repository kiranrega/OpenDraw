# Database URL (required for Prisma)
DATABASE_URL="postgresql://username:password@localhost:5432/opendraw"

# JWT Secret for token signing and verification (required)
JWT_SECRET="your-secret-key-change-this-in-production"

# Server Port (optional, defaults to 3001)
PORT=3001

# Allowed CORS origins (comma-separated, required for production)
ALLOWED_ORIGINS="http://localhost:3000,https://yourdomain.com"

# Environment
NODE_ENV="development"
