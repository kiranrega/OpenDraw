# JWT Secret for token verification (required, must match http-backend)
JWT_SECRET="your-secret-key-change-this-in-production"

# WebSocket Server Port (optional, defaults to 8080)
PORT=8080

# Environment
NODE_ENV="development"

# Database URL (optional, needed only if you store WebSocket state)
DATABASE_URL="postgresql://username:password@localhost:5432/opendraw"
